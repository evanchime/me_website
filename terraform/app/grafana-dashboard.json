{
  "title": "Django Website: Full Observability",
  "panels": [
    {
      "title": "1. Request Latency (App)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_duration_milliseconds_sum[5m]) / rate(http_server_duration_milliseconds_count[5m])",
          "legendFormat": "Avg Latency (ms)"
        }
      ]
    },
    {
      "title": "2. HTTP Request Volume",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count[5m])) by (http_status_code)",
          "legendFormat": "Status: {{http_status_code}}"
        }
      ]
    },
    {
      "title": "3. Fargate CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container='me-website'}[5m]))",
          "legendFormat": "vCPU Load"
        }
      ]
    },
    {
      "title": "4. Memory Usage (Working Set)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 2147483648,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1073741824, "color": "orange" },
              { "value": 1717986918, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container='me-website'})",
          "legendFormat": "Memory Bytes"
        }
      ]
    },
    {
      "title": "5. Network Traffic (Outbound)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total[5m]))",
          "legendFormat": "Bytes/sec Out"
        }
      ]
    }
  ]
}
