{
  "title": "Django Website: Full Observability",
  "panels": [
    {
      "title": "1. Request Latency (App)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_duration_sum[5m]) / rate(http_server_duration_count[5m])",
          "legendFormat": "Avg Latency (ms)"
        }
      ]
    },
    {
      "title": "2. HTTP Request Volume",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count[5m])) by (http_status_code)",
          "legendFormat": "Status: {{http_status_code}}"
        }
      ]
    },
    {
      "title": "3. Fargate CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pod_cpu_usage_total[5m]))",
          "legendFormat": "vCPU Usage (Total)"
        }
      ]
    },
    {
      "title": "4. Memory (Working Set)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "pod_memory_working_set",
          "legendFormat": "Memory Bytes"
        }
      ]
    },
    {
      "title": "5. Network Outbound",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus_uid}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pod_network_tx_bytes[5m]))",
          "legendFormat": "Bytes/sec Out"
        }
      ]
    }
  ]
}